# Database Connection URL (Neon)
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# Server Port
PORT=5000

# RapidAPI Key (Social Download All In One)
# YouTube aur TikTok downloads ke liye REQUIRED
# Facebook/Instagram ke liye sirf fallback use hoga
# Get from: https://rapidapi.com/social-download-all-in-one
RAPIDAPI_KEY="your-rapidapi-key-here"

# SMTP (Email) Settings for Contact/Report forms
# Use Gmail App Passwords if using a Google account
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-app-password"
CONTACT_EMAIL="your-receiver-email@gmail.com"
